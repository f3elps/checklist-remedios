{
  "brand": {
    "name": "Cuidi",
    "tagline": "Cuidado calmo",
    "note": "Mockup original gerado com o nome 'Remedinhos' (renomeado para Cuidi)."
  },
  "font": {
    "sans": "Plus Jakarta Sans",
    "import": "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap",
    "weights": [
      400,
      500,
      600,
      700,
      800
    ],
    "baseSizePx": 16
  },
  "radius": {
    "sm": ".625rem",
    "md": "1rem",
    "lg": "1.5rem"
  },
  "shadow": {
    "card-light": "0 8px 24px -10px hsl(200 30% 40% / .2)",
    "card-dark": "0 8px 24px -10px hsl(200 60% 3% / .55)"
  },
  "themes": {
    "verde": {
      "label": "Verde Cuidado",
      "default": true,
      "hsl": {
        "h": 160,
        "s": 60,
        "l": 40
      },
      "light": {
        "--surface-2": "hsl(160 30% 97%)",
        "--primary": "hsl(160 60% 40%)",
        "--primary-strong": "hsl(160 60% 31%)",
        "--primary-soft": "hsl(160 60% 95%)"
      },
      "dark": {
