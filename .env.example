# Cuidi — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais do seu projeto Supabase.
# (.env.local é gitignored — nunca commite suas chaves.)

# Painel Supabase > Project Settings > Data API / API Keys
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-a-publishable-key-aqui
